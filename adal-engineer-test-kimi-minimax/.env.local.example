# LLM provider for idea generation.
# Any OpenAI-compatible chat-completions endpoint works (OpenAI, OpenRouter, Together, Groq, Ollama with --openai-compatible, etc.).
# If any of these are missing, idea generation is disabled and a banner is shown — the atlas keeps working.

VITE_LLM_BASE_URL=https://api.openai.com/v1
VITE_LLM_API_KEY=
VITE_LLM_MODEL=gpt-4o-mini

# When VITE_LLM_MOCK=1 the LLM module returns deterministic canned ideas instead of
# hitting the network. Use this to test the full UI pipeline without an API key.
# VITE_LLM_MOCK=1

# Copy this file to server/.env and fill in your key(s).
# server/.env is gitignored — never commit real keys.

# REQUIRED for idea generation (POST /api/generate). Without this,
# /api/generate returns a 503 NO_LLM_PROVIDER error (clear message,
# no crash) — edge/similarity computation still works via keyword-Jaccard
# fallback, but idea generation itself has no template-based substitute.
OPENAI_API_KEY=

# Optional — defaults shown. Used for cosine-similarity edges; if
# OPENAI_API_KEY is unset, embeddings are skipped entirely and similarity
# falls back to keyword-overlap Jaccard.
EMBEDDING_MODEL=text-embedding-3-small

# Optional — defaults shown. Used for idea generation chat completions.
CHAT_MODEL=gpt-4o-mini

# Optional — backend API port (default 8787).
PORT=8788

# Stretch/optional — X/Twitter source is currently a stub that always
# returns [] regardless of this value (see server/lib/sources/x.mjs and
# README "Known Limitations"). Left here as the documented extension point.
X_BEARER_TOKEN=

# Demo/testing only — when MOCK_LLM=1 and no real OPENAI_API_KEY is set,
# the server returns deterministic mock ideas through the SAME data contract,
# so the UI flow is demonstrable end-to-end. Never use in production.
MOCK_LLM=
